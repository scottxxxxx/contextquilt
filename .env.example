# ContextQuilt Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ============================================
# Required — LLM provider for extraction
# ============================================
# Any OpenAI-compatible API (OpenRouter, OpenAI, Ollama, vLLM, LiteLLM)
CQ_LLM_API_KEY=sk-or-your-api-key-here
CQ_LLM_BASE_URL=https://openrouter.ai/api/v1
CQ_LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct

# ============================================
# Required — Security
# ============================================
CQ_ADMIN_KEY=change-me-to-a-strong-random-string
JWT_SECRET_KEY=change-me-to-a-different-strong-random-string

# ============================================
# Database (defaults work for docker-compose)
# ============================================
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=redis

# ============================================
# Required — Key encryption (protects BYOK LLM keys at rest)
# ============================================
CQ_KEY_ENCRYPTION_KEY=change-me-to-a-strong-random-string

# ============================================
# Optional — MCP Server
# ============================================
# Set to protect the MCP endpoint with a bearer token.
# Leave empty for local dev (no auth required).
# MCP_API_KEY=your-mcp-api-key

# ============================================
# Optional — Tuning
# ============================================
# CQ_QUEUE_MAX_WAIT_MINUTES=60       # Meeting queue consolidation window
# MEMORY_RETENTION_DAYS=90           # Default patch retention
# CACHE_TTL_SECONDS=3600             # Redis cache TTL
