# Context Quilt Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# API Configuration
# ============================================
CONTEXT_QUILT_API_PORT=8000
CONTEXT_QUILT_HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================
# LLM Provider API Keys
# ============================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORG_ID=  # Optional

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (if using Gemini)
GOOGLE_API_KEY=  # Optional

# Cohere (if using)
COHERE_API_KEY=  # Optional

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=context_quilt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-secure-password-123

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password-456
REDIS_DB=0

# ============================================
# Authentication & Security
# ============================================
# Used to hash API keys - generate a random string
CONTEXT_QUILT_API_KEY_SALT=generate-a-random-salt-here-xyz789

# JWT secret for internal auth (if needed)
JWT_SECRET=generate-a-random-jwt-secret-here

# ============================================
# Feature Flags
# ============================================
ENABLE_CACHING=true
ENABLE_AB_TESTING=true
ENABLE_PII_DETECTION=false
ENABLE_MEMORY_ENRICHMENT=true
ENABLE_SMART_ROUTING=true

# ============================================
# Caching Configuration
# ============================================
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=256

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================
# Memory & Context Configuration
# ============================================
MAX_MEMORY_HISTORY_ITEMS=10
MEMORY_RETENTION_DAYS=90
AUTO_SUMMARIZE_CONVERSATIONS=true

# ============================================
# Model Defaults
# ============================================
DEFAULT_MODEL=gpt-4
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1000

# ============================================
# Observability
# ============================================
# Enable detailed logging
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true

# Metrics export (if using Prometheus/Grafana)
ENABLE_METRICS=false
METRICS_PORT=9090

# ============================================
# Development Tools (Optional)
# ============================================
# pgAdmin credentials (only for development)
PGADMIN_EMAIL=admin@contextquilt.local
PGADMIN_PASSWORD=admin

# ============================================
# Advanced Configuration
# ============================================
# Worker configuration for production
WORKERS=4
MAX_CONNECTIONS=100
KEEP_ALIVE=5

# Timeout settings (seconds)
REQUEST_TIMEOUT=60
LLM_TIMEOUT=120

# ============================================
# Cost Management
# ============================================
# Budget alerts (USD per day)
DAILY_COST_BUDGET=100
ENABLE_COST_ALERTS=true
COST_ALERT_EMAIL=alerts@yourcompany.com

# ============================================
# Compliance & Privacy
# ============================================
# Data retention
LOG_RETENTION_DAYS=30
CONVERSATION_RETENTION_DAYS=90

# Privacy settings
ANONYMIZE_LOGS=false
ENABLE_AUDIT_LOG=true
