# Context Quilt Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# API Configuration
# ============================================
CONTEXT_QUILT_API_PORT=8000
CONTEXT_QUILT_HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================
# LLM Provider API Keys
# ============================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORG_ID=  # Optional

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (if using Gemini)
GOOGLE_API_KEY=  # Optional

# Cohere (if using)
COHERE_API_KEY=  # Optional

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=context_quilt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-secure-password-123

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password-456
REDIS_DB=0

# ============================================
# Authentication & Security
# ============================================
# Used to hash API keys - generate a random string
CONTEXT_QUILT_API_KEY_SALT=generate-a-random-salt-here-xyz789

# JWT secret for internal auth (if needed)
JWT_SECRET=generate-a-random-jwt-secret-here

# Admin dashboard key (long random string - required when exposed to public IP)
CQ_ADMIN_KEY=generate-a-long-random-key-here

# ============================================
# Feature Flags
# ============================================
ENABLE_CACHING=true
ENABLE_AB_TESTING=true
ENABLE_PII_DETECTION=false
ENABLE_MEMORY_ENRICHMENT=true
ENABLE_SMART_ROUTING=true

# ============================================
# Caching Configuration
# ============================================
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=256

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================
# Memory & Context Configuration
# ============================================
MAX_MEMORY_HISTORY_ITEMS=10
MEMORY_RETENTION_DAYS=90
AUTO_SUMMARIZE_CONVERSATIONS=true

# ============================================
# Model Defaults (Hot Path - user-facing LLM calls)
# ============================================
DEFAULT_MODEL=gpt-4
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1000

# ============================================
# Cold Path Extraction Model (Context Quilt worker)
# ============================================
# This model is used for background fact extraction, NOT user queries.
# Works with ANY OpenAI-compatible API endpoint — hosted or local.
# Just set the base URL, API key, and model name for your provider.
#
# --- Option 1: OpenRouter (recommended, access to 200+ models) ---
# Default: Claude Haiku 4.5 — best quality on real messy transcripts per
# our benchmark (see tests/benchmark/test_you_marker_gating.py). ~$0.029/meeting.
CQ_LLM_API_KEY=sk-or-your-openrouter-key-here
CQ_LLM_BASE_URL=https://openrouter.ai/api/v1
CQ_LLM_MODEL=anthropic/claude-haiku-4.5
#
# Alternatives via OpenRouter (all pass the (you)-marker gating test):
# CQ_LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct  # cheapest (~$0.0006) but slow + quality quirks
# CQ_LLM_MODEL=google/gemini-2.5-flash-lite              # fastest (~6s) but over-extracts self-typed on real data
# CQ_LLM_MODEL=google/gemini-2.5-flash                    # good, but ~2x cost of Haiku
# CQ_LLM_MODEL=deepseek/deepseek-chat-v3-0324             # decent quality, slow (~60s)
#
# --- Option 2: OpenAI direct ---
# CQ_LLM_API_KEY=sk-your-openai-key
# CQ_LLM_BASE_URL=https://api.openai.com/v1
# CQ_LLM_MODEL=gpt-4.1-nano
#
# --- Option 3: Google Gemini direct ---
# CQ_LLM_API_KEY=AIza-your-google-key
# CQ_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CQ_LLM_MODEL=gemini-2.5-flash-lite
#
# --- Option 4: Local model via Ollama (free, no API key needed) ---
# CQ_LLM_API_KEY=ollama
# CQ_LLM_BASE_URL=http://localhost:11434/v1
# CQ_LLM_MODEL=qwen2.5:7b
#
# --- Option 5: Local model via vLLM / LiteLLM / LM Studio ---
# CQ_LLM_API_KEY=not-needed
# CQ_LLM_BASE_URL=http://localhost:8000/v1
# CQ_LLM_MODEL=your-model-name

# ============================================
# Meeting Queue / Batching
# ============================================
# Events with a meeting_id are buffered and processed as a batch.
# Two triggers: time window (quiet period) or context budget (too much content).
CQ_QUEUE_MAX_WAIT_MINUTES=60
CQ_QUEUE_BUDGET_THRESHOLD=0.8
# Override context window if using a model CQ doesn't recognize (tokens):
# CQ_LLM_CONTEXT_WINDOW=128000

# ============================================
# Observability
# ============================================
# Enable detailed logging
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true

# Metrics export (if using Prometheus/Grafana)
ENABLE_METRICS=false
METRICS_PORT=9090

# ============================================
# Development Tools (Optional)
# ============================================
# pgAdmin credentials (only for development)
PGADMIN_EMAIL=admin@contextquilt.local
PGADMIN_PASSWORD=admin

# ============================================
# Advanced Configuration
# ============================================
# Worker configuration for production
WORKERS=4
MAX_CONNECTIONS=100
KEEP_ALIVE=5

# Timeout settings (seconds)
REQUEST_TIMEOUT=60
LLM_TIMEOUT=120

# ============================================
# Cost Management
# ============================================
# Budget alerts (USD per day)
DAILY_COST_BUDGET=100
ENABLE_COST_ALERTS=true
COST_ALERT_EMAIL=alerts@yourcompany.com

# ============================================
# Compliance & Privacy
# ============================================
# Data retention
LOG_RETENTION_DAYS=30
CONVERSATION_RETENTION_DAYS=90

# Privacy settings
ANONYMIZE_LOGS=false
ENABLE_AUDIT_LOG=true
